```
# Flutter/Dart specific ignores
.dart_tool/
.build/
.pub/
*.g.dart
*.freezed.dart
*.config.dart

# Dependencies
node_modules/
vendor/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build outputs
build/
dist/
target/

# Python related (if any Python in project)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.temp
*~
```